# FavoriteWeb server configuration
# Do not commit real secret values here.
FLASK_SECRET_KEY=change-me
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Preferred: enables Cloudflare Workers AI for Article Generate.
# Create a Workers AI REST API token in Cloudflare and set both values on Render/PC servers.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_AI_MODEL=@cf/zai/glm-4.7-flash

# Optional fallback: enables OpenAI-powered Article Generate output if Cloudflare AI is not configured.
# Without any cloud key, Article Generate uses the local education fallback and validator.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.6
