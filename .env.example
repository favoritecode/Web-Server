# FavoriteWeb server configuration
# Do not commit real secret values here.
FLASK_SECRET_KEY=change-me
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: enables OpenAI-powered Article Generate output.
# Without this key, Article Generate uses the local education fallback and validator.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.6