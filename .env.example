# FavoriteWeb server configuration
# Do not commit real secret values here.
FLASK_SECRET_KEY=change-me
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Preferred: enables Gemini-powered Article Generate output.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional fallback: enables NVIDIA NIM-powered Article Generate output.
NVIDIA_API_KEY=
NVIDIA_MODEL=deepseek-ai/deepseek-v4-flash
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1

# Optional fallback: enables Cloudflare Workers AI for Article Generate.
# Create a Workers AI REST API token in Cloudflare and set both values on Render/PC servers.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_AI_MODEL=@cf/meta/llama-3.2-3b-instruct

# Optional fallback: enables OpenAI-powered Article Generate output if Cloudflare AI is not configured.
# Without any cloud key, Article Generate uses the local education fallback and validator.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.6

# Local Media Transcribe models. Bangla defaults to the more accurate multilingual medium model.
MEDIA_TRANSCRIBE_MODEL=small
MEDIA_TRANSCRIBE_ENGINE=auto
MEDIA_TRANSCRIBE_BANGLA_MODEL=medium
MEDIA_TRANSCRIBE_DEVICE=cpu
MEDIA_TRANSCRIBE_COMPUTE=int8
MEDIA_TRANSCRIBE_GEMINI_CHUNK_SECONDS=300
NVIDIA_WHISPER_FUNCTION_ID=b702f636-f60c-4a3d-a6f4-f3568c13bd7d
NVIDIA_WHISPER_SERVER=grpc.nvcf.nvidia.com:443
